# Fantasy Auction Platform — environment configuration
# Copy to .env and fill in. The Reflex app reads these at startup.

# --- Firebase Realtime Database (the datastore — PLAN.md §6.6) ---
# Base URL of your Firebase Realtime DB, no trailing slash:
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
# Optional legacy DB secret (appended as ?auth=). Leave blank to use rules-based/open access.
FIREBASE_SECRET=

# Local write-through cache / fallback file (used when FIREBASE_DATABASE_URL is unset).
AUCTION_DATA_FILE=auction_data.json

# Public backend URL the browser uses in production (VPS). Dev default is fine locally.
API_URL=http://localhost:8000
